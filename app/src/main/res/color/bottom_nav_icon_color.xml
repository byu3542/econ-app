<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gold when the item is selected/active -->
    <item android:state_checked="true" android:color="#c9a84c" />
    <!-- White at ~35% opacity when unselected -->
    <item android:color="#59FFFFFF" />
</selector>
