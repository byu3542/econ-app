<?xml version="1.0" encoding="utf-8"?>
<!--
    Center-nav FAB artwork: the app launcher icon (navy gradient +
    gold yield curve) scaled to 72% about center so the full curve,
    terminus dot, baseline and ticks fit inside a circular crop.
    Clipped to a circle by ShapeableImageView in activity_main.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Navy gradient background: top-left #1a2845 -> bottom-right #0a1020 -->
    <path android:pathData="M0,0h108v108H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0" android:color="#FF1A2845"/>
                <item android:offset="1" android:color="#FF0A1020"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Warm gold radial glow, lower-left -->
    <path android:pathData="M0,0h108v108H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32"
                android:centerY="76"
                android:gradientRadius="64">
                <item android:offset="0" android:color="#1FC9A84C"/>
                <item android:offset="1" android:color="#00C9A84C"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Foreground art scaled to fit the circular crop -->
    <group
        android:scaleX="0.72"
        android:scaleY="0.72"
        android:pivotX="54"
        android:pivotY="54">

        <!-- Area fill under the curve -->
        <path
            android:pathData="M10,62 C16,62 20,64 26,66
                              C32,68 34,70 38,68
                              C44,64 46,55 52,46
                              C58,37 66,26 80,18
                              C86,14 92,14 96,14
                              L96,108 L10,108 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="0"
                    android:startY="14"
                    android:endX="0"
                    android:endY="108">
                    <item android:offset="0" android:color="#40C9A84C"/>
                    <item android:offset="1" android:color="#00C9A84C"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Yield curve stroke -->
        <path
            android:pathData="M10,62 C16,62 20,64 26,66
                              C32,68 34,70 38,68
                              C44,64 46,55 52,46
                              C58,37 66,26 80,18
                              C86,14 92,14 96,14"
            android:fillColor="#00000000"
            android:strokeColor="#C9A84C"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"/>

        <!-- Terminus glow ring -->
        <path
            android:pathData="M96,3 A11,11,0,1,0,96,25 A11,11,0,1,0,96,3 Z"
            android:fillColor="#26E0C070"/>

        <!-- Terminus dot -->
        <path
            android:pathData="M96,8 A6,6,0,1,0,96,20 A6,6,0,1,0,96,8 Z"
            android:fillColor="#FFE0C070"/>

        <!-- Baseline -->
        <path
            android:pathData="M10,96 L96,96"
            android:fillColor="#00000000"
            android:strokeColor="#33C9A84C"
            android:strokeWidth="1"/>

        <!-- Tick marks -->
        <path
            android:pathData="M10,96 L10,100 M35,96 L35,100 M60,96 L60,100 M96,96 L96,100"
            android:fillColor="#00000000"
            android:strokeColor="#4DC9A84C"
