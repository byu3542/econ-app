<?xml version="1.0" encoding="utf-8"?>
<!-- Switches between filled (active) and outline (inactive) Overview icon. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true"  android:drawable="@drawable/ic_overview_filled" />
    <item                               android:drawable="@drawable/ic_overview_outline" />
</selector>
