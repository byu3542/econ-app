    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M3,3H11V13H3V3z" />
    <!-- Top-right short rectangle -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M13,3H21V9H13V3z" />
    <!-- Bottom-right tall rectangle -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M13,11H21V21H13V11z" />
    <!-- Bottom-left short rectangle -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M3,15H11V21H3V15z" />
</vector>
