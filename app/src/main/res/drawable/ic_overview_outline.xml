<?xml version="1.0" encoding="utf-8"?>
<!--
  Overview — OUTLINE / INACTIVE state
  Same 2×2 grid geometry as the filled version, drawn as hollow
  stroke-only rectangles.  strokeColor="#FFFFFF" so itemIconTint
  can recolor it correctly via the SRC_IN color filter.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
