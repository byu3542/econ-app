<?xml version="1.0" encoding="utf-8"?>
<!--
    Center-nav FAB artwork, Option A (rebalanced): brighter gold disc,
    navy sparkle centered with the small companion star given more air.

    The disc and ring are drawn as vector circle paths (anti-aliased)
    instead of relying on the MaterialCardView's clipToOutline circle
    crop, which is NOT anti-aliased and produced pixelated edges.
    Ring color uses @color/fab_ring so it adapts to dark mode.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer ring (3dp at 62dp render size ≈ 5.2 viewport units) -->
    <path
        android:fillColor="@color/fab_ring"
        android:pathData="M54,1 a53,53 0 1,1 -0.01,0 z"/>

    <!-- Gold disc -->
    <path
        android:fillColor="#D2B156"
        android:pathData="M54,6.2 a47.8,47.8 0 1,1 -0.01,0 z"/>

    <!-- Main 4-point sparkle, navy, centered -->
    <path
        android:fillColor="#1A1A2E"
        android:pathData="M52,35 L57.75,52.25 L75,58 L57.75,63.75 L52,81 L46.25,63.75 L29,58 L46.25,52.25 Z"/>

    <!-- Small companion sparkle, top-right, pulled in from the ring edge -->
    <path
        android:fillColor="#1A1A2E"
        android:pathData="M76,20 L78.5,27.5 L86,30 L78.5,32.5 L76,40 L73.5,32.5 L66,30 L73.5,27.5 Z"/>

</vector>
