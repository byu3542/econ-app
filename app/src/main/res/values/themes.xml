<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. DayNight — dark palette lives in values-night/colors.xml. -->
    <style name="Theme.EconomicDashboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Status bar: solid navy, non-translucent, light icons -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">#0f1729</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Alabaster specific styling -->
        <item name="toolbarStyle">@style/AlabasterToolbar</item>
        <item name="tabStyle">@style/AlabasterTabLayout</item>

        <!-- Rounded long-press context menus (Ask AI Analyst / Explain chart / news) -->
        <item name="android:popupMenuStyle">@style/RoundedPopupMenu</item>
        <item name="popupMenuStyle">@style/RoundedPopupMenu</item>
    </style>

    <style name="RoundedPopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_rounded</item>
    </style>

    <!-- Full screen dialog theme for AI Chat (kept for reference) -->
    <style name="Theme.EconomicDashboard.FullScreenDialog" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@color/bg_warm_off_white</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_up</item>
        <item name="android:windowExitAnimation">@anim/slide_out_down</item>
    </style>

    <!-- Half-sheet bottom sheet theme for AI Chat (v2) -->
    <style name="Theme.EconomicDashboard.BottomSheet" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/EconomicBottomSheetStyle</item>
    </style>

    <style name="EconomicBottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@color/bg_warm_off_white</item>
        <item name="shapeAppearanceOverlay">@style/BottomSheetRoundedCorners</item>
        <item name="android:elevation">16dp</item>
    </style>

    <style name="BottomSheetRoundedCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="AlabasterToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/cardBackground</item>
        <item name="titleTextColor">@color/textPrimary</item>
        <item name="subtitleTextColor">@color/textSecondary</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="AlabasterTabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:background">@color/cardBackground</item>
        <item name="tabIndicatorColor">@color/alabaster_dark_gray</item>
        <item name="tabSelectedTextColor">@color/textPrimary</item>
        <item name="tabTextColor">@color/textSecondary</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabTextAppearance">@style/AlabasterTabTextAppearance</item>
    </style>

    <style name="AlabasterTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">@dimen/text_secondary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Style referenced in fragment_dashboard.xml -->
    <style name="TabLabelStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- ── Economy secondary tab row ─────────────────────────────────────── -->
    <style name="EconomyTabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:background">@color/economy_tab_bg</item>
        <item name="tabIndicatorColor">@color/accent_gold</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabSelectedTextColor">@color/text_navy</item>
        <item name="tabTextColor">@color/economy_tab_text_unselected</item>
        <item name="tabTextAppearance">@style/EconomyTabTextAppearance</item>
        <item name="tabRippleColor">@color/divider_sand</item>
    </style>

    <style name="EconomyTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- ── Bottom navigation bar ─────────────────────────────────────────── -->
    <style name="BottomNavLabelStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!--
      Suppresses the default Material pill/ripple indicator behind the nav icon
      so our custom 2dp top-line indicator (navActiveIndicator View) is used instead.
      No parent — the ActiveIndicator parent style name varies across MC versions.
    -->
    <style name="BottomNavActiveIndicatorNone">
        <item name="android:color">@android:color/transparent</item>
        <item name="android:height">0dp</item>
        <item name="android:width">0dp</item>
    </style>

    <!-- Update AI bottom sheet corners to match mockup (24dp) -->
    <style name="BottomSheetRoundedCorners24">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Updated bottom sheet style using 24dp corners -->
    <style name="EconomicBottomSheetStyle24" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@color/bg_warm_off_white</item>
        <item name="shapeAppearanceOverlay">@style/BottomSheetRoundedCorners24</item>
        <item name="android:elevation">16dp</item>
    </style>

    <style name="Theme.EconomicDashboard.BottomSheet24" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/EconomicBottomSheetStyle24</item>
    </style>

    <!-- Fed Funds hero card — navy background, overrides the app's default card colour -->
    <style name="FedFundsHeroCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#0f1729</item>
        <item name="cardElevation">3dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <!-- Circular crop for the center-nav AI Analyst button -->
    <style name="CircleFabOverlay">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ── Settings sheet ─────────────────────────────────────────────────── -->
    <style name="SettingsSectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.2</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:drawablePadding">6dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginBottom">@dimen/space_sm</item>
    </style>

    <!-- Card that wraps each settings section -->
    <style name="SettingsCard" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/space_md</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/divider_sand</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">@dimen/space_lg</item>
        <item name="contentPaddingBottom">@dimen/space_md</item>
        <item name="contentPaddingTop">@dimen/space_md</item>
    </style>

    <!-- Brand-tinted switch: gold track when on, muted when off -->
    <style name="SettingsSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="useMaterialThemeColors">false</item>
        <item name="thumbTint">@color/settings_switch_thumb</item>
        <item name="trackTint">@color/settings_switch_track</item>
    </style>

    <!-- Destructive outlined button (clear chat / clear cache) -->
    <style name="SettingsDestructiveButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/error_text</item>
        <item name="strokeColor">@color/error_bubble_stroke</item>
        <item name="rippleColor">@color/error_bubble_bg</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="SettingsRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="SettingsRowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SettingsRowTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_navy</item>
    </style>

    <style name="SettingsRowSub">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_secondary</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Segmented buttons for the settings pickers (theme / startup tab / decimals) -->
    <style name="SettingsSegmentButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>

    <!-- Shimmer skeleton placeholders (Overview) -->
    <style name="SkeletonRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_marginBottom">@dimen/space_lg</item>
        <item name="android:baselineAligned">false</item>
    </style>
    <style name="SkeletonCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">130dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_skeleton_block</item>
    </style>

    <!-- ── Overview metric grouping (TICKET-05) ──────────────────────────── -->
    <!-- Gold, all-caps label above each KPI cluster. -->
    <style name="MetricGroupHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textColor">@color/accent_gold</item>
        <item name="android:layout_marginBottom">@dimen/space_sm</item>
    </style>

    <!-- Bordered "common region" holding a cluster's KPI cards. -->
    <style name="MetricGroupRegion">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:baselineAligned">false</item>
        <item name="android:background">@drawable/bg_metric_group</item>
        <item name="android:padding">@dimen/space_sm</item>
    </style>
</resources>
