<?xml version="1.0" encoding="utf-8"?>
<!-- Design tokens: type scale (11sp floor) + 4dp-grid spacing.
     All layouts reference these instead of inline literals. -->
<resources>
    <!-- Type scale -->
    <dimen name="text_caption">11sp</dimen>      <!-- overlines, chips, fine print -->
    <dimen name="text_secondary">13sp</dimen>    <!-- secondary copy, dates -->
    <dimen name="text_body">15sp</dimen>         <!-- body copy -->
    <dimen name="text_title">18sp</dimen>        <!-- card/section titles -->
    <dimen name="text_headline">22sp</dimen>     <!-- screen sub-headers -->
    <dimen name="text_display">28sp</dimen>      <!-- KPI values, masthead -->
    <dimen name="text_display_lg">34sp</dimen>   <!-- large metric values -->
    <dimen name="text_display_xl">48sp</dimen>   <!-- hero metric value -->

    <!-- Spacing (4dp grid) -->
    <dimen name="space_hairline">2dp</dimen>
    <dimen name="space_xs">4dp</dimen>
    <dimen name="space_sm">8dp</dimen>
    <dimen name="space_md">12dp</dimen>
    <dimen name="space_lg">16dp</dimen>
    <dimen name="space_xl">20dp</dimen>
    <dimen name="space_2xl">24dp</dimen>
    <dimen name="space_3xl">28dp</dimen>
    <dimen name="space_4xl">32dp</dimen>
</resources>
