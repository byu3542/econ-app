<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:paddingBottom="@dimen/space_3xl">

        <!-- Drag handle: Material component (built-in touch target + accessibility) -->
        <com.google.android.material.bottomsheet.BottomSheetDragHandleView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:tint="@color/handle_on_surface"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:layout_marginBottom="@dimen/space_md"
            android:text="@string/settings"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.1"
            android:textColor="@color/text_navy"/>

        <!-- ~~ APPEARANCE ~~ -->
        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsSectionHeader"
                    android:drawableStart="@drawable/ic_set_palette"
                    android:text="@string/section_appearance"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/tgTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeLight"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/theme_light"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeDark"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/theme_dark"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeSystem"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/theme_system"/>
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/colorblind_title"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/colorblind_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchColorblind"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/colorblind_title"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ~~ DATA ~~ -->
        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsSectionHeader"
                    android:drawableStart="@drawable/ic_set_data"
                    android:text="@string/section_data"/>

                <TextView
                    android:id="@+id/tvLastUpdated"
                    style="@style/SettingsRowSub"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:text="@string/checking_freshness"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRefreshNow"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:text="@string/refresh_data"
                        android:textAllCaps="false"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_navy"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCache"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/clear_cache"
                        android:textAllCaps="false"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_navy"/>
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/refresh_on_open"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/refresh_on_open_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchRefreshOnOpen"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/refresh_on_open"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ~~ STARTUP TAB ~~ -->
        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsSectionHeader"
                    android:drawableStart="@drawable/ic_set_home"
                    android:text="@string/section_startup_tab"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgDefaultTab"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="@dimen/space_sm">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTabOverview"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_overview"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTabMarkets"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_markets"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTabEconomy"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_economy"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTabNews"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_news"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ~~ NEWS SOURCES ~~ -->
        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsSectionHeader"
                    android:drawableStart="@drawable/ic_set_news"
                    android:text="@string/section_news_sources"/>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/news_gov"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/news_gov_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNewsGov"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/news_gov"/>
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/news_media"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/news_media_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNewsMedia"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/news_media"/>
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/news_intl"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/news_intl_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNewsIntl"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/news_intl"/>
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/news_research"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/news_research_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNewsResearch"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/news_research"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ~~ AI ANALYST ~~ -->
        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsSectionHeader"
                    android:drawableStart="@drawable/ic_set_ai"
                    android:text="@string/section_ai_analyst"/>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/smart_chips"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/smart_chips_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSmartChips"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/smart_chips"/>
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/detailed_ai"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/detailed_ai_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDetailedAi"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/detailed_ai"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearChat"
                    style="@style/SettingsDestructiveButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/clear_chat_history"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ~~ CHARTS ~~ -->
        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsSectionHeader"
                    android:drawableStart="@drawable/ic_set_chart"
                    android:text="@string/section_charts"/>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/gridlines"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/gridlines_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchGridlines"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/gridlines"/>
                </LinearLayout>

                <TextView style="@style/SettingsRowTitle"
                    android:layout_marginTop="@dimen/space_sm"
                    android:layout_marginBottom="@dimen/space_xs"
                    android:text="@string/axis_decimals"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/tgDecimals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDec1"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/dec_one"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDec2"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/dec_two"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDec3"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/dec_three"/>
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView style="@style/SettingsRowTitle"
                    android:layout_marginTop="@dimen/space_sm"
                    android:layout_marginBottom="@dimen/space_xs"
                    android:text="@string/chart_timeframe"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/tgTimeframe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTf3m"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/tf_3m"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTf6m"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/tf_6m"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTf1y"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/tf_1y"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTf2y"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/tf_2y"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTf5y"
                        style="@style/SettingsSegmentButton"
                        android:text="@string/tf_5y"/>
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView style="@style/SettingsRowSub"
                    android:layout_marginTop="@dimen/space_sm"
                    android:textStyle="italic"
                    android:text="@string/chart_apply_note"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ~~ NOTIFICATIONS ~~ -->
        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsSectionHeader"
                    android:drawableStart="@drawable/ic_set_bell"
                    android:text="@string/section_notifications"/>

                <TextView
                    android:id="@+id/tvNotifBlocked"
                    style="@style/SettingsRowSub"
                    android:textColor="@color/info_blue"
                    android:background="?attr/selectableItemBackground"
                    android:paddingTop="@dimen/space_xs"
                    android:paddingBottom="@dimen/space_xs"
                    android:visibility="gone"
                    android:text="@string/notif_blocked_tap"/>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/notify_moves"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/notify_moves_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNotifyMoves"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/notify_moves"/>
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/notify_releases"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/notify_releases_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNotifyReleases"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/notify_releases"/>
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/daily_brief"/>
                        <TextView style="@style/SettingsRowSub" android:text="@string/daily_brief_sub"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDailyBrief"
                        style="@style/SettingsSwitch"
                        android:contentDescription="@string/daily_brief"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ~~ ABOUT (footer) ~~ -->
        <TextView
            android:id="@+id/tvVersion"
            style="@style/SettingsRowSub"
            android:layout_marginTop="@dimen/space_xl"
            android:gravity="center"
            android:drawableTint="@color/text_muted"
            android:text="Econ Monitor"/>

        <TextView
            style="@style/SettingsRowSub"
            android:layout_marginTop="@dimen/space_hairline"
            android:gravity="center"
            android:textSize="@dimen/text_caption"
            android:text="@string/about_data_note"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
