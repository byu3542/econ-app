<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/space_lg"
    android:paddingVertical="@dimen/space_sm"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Sender Label (YOU / ANALYST) — shown only on the first message of a run -->
    <TextView
        android:id="@+id/tvSenderLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YOU"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_caption"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="@dimen/space_xs"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0" />

    <!-- Message Bubble -->
    <LinearLayout
        android:id="@+id/llBubbleContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingVertical="@dimen/space_md"
        android:minWidth="60dp"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginTop="@dimen/space_hairline"
        app:layout_constraintTop_toBottomOf="@id/tvSenderLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintWidth_default="wrap">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_navy"
            android:textSize="@dimen/text_body"
            android:textIsSelectable="false"
            android:lineSpacingExtra="4dp" />

        <!-- Attached image (vision messages) -->
        <ImageView
            android:id="@+id/ivChatImage"
            android:layout_width="180dp"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/space_sm"
            android:scaleType="centerCrop"
            android:contentDescription="Attached image"
            android:visibility="gone" />

        <!-- Inline sparkline rendered from a [CHART:...] tag -->
        <com.economic.dashboard.views.SparklineView
            android:id="@+id/sparklineChart"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="@dimen/space_sm"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvChartCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption"
            android:visibility="gone" />

        <!-- Explicit retry affordance for error bubbles -->
        <TextView
            android:id="@+id/tvRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="↻  Retry"
            android:textSize="@dimen/text_secondary"
            android:textStyle="bold"
            android:textColor="@color/error_text"
            android:background="@drawable/bg_retry_pill"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="@dimen/space_xs"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

        <!-- Typing Indicator Container -->
        <LinearLayout
            android:id="@+id/llTypingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="@dimen/space_md"
            android:paddingBottom="@dimen/space_xs"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone">

            <View
                android:id="@+id/dot1"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_neutral"
                android:backgroundTint="@color/text_navy"
                android:layout_marginEnd="@dimen/space_xs" />

            <View
                android:id="@+id/dot2"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_neutral"
                android:backgroundTint="@color/text_navy"
                android:layout_marginEnd="@dimen/space_xs" />

            <View
                android:id="@+id/dot3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_neutral"
                android:backgroundTint="@color/text_navy" />

        </LinearLayout>

    </LinearLayout>

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="9:38 AM"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_caption"
        android:layout_marginTop="@dimen/space_xs"
        app:layout_constraintTop_toBottomOf="@id/llBubbleContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0" />

</androidx.constraintlayout.widget.ConstraintLayout>
