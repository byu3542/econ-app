<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/space_lg">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardUnemploymentStatus"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="@dimen/space_sm"
                app:cardCornerRadius="16dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/header_navy">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/space_lg" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="UNEMPLOYMENT RATE" android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_secondary" android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.1" />
                    <TextView android:id="@+id/tvUnempValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="&#8212;"
                        android:textColor="@color/card_white" android:textSize="@dimen/text_display"
                        android:fontFamily="serif" android:textStyle="bold" android:layout_marginTop="@dimen/space_xs" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_xs">
                        <View android:id="@+id/viewUnempIndicatorDot" android:layout_width="8dp"
                            android:layout_height="8dp" android:layout_marginEnd="@dimen/space_sm" />
                        <TextView android:id="@+id/tvUnempStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="&#8212;"
                            android:textColor="@color/text_on_navy_muted" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvUnempLowInfo" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Vs 12-month low"
                        android:textColor="@color/slate_dim" android:textSize="@dimen/text_caption" android:layout_marginTop="@dimen/space_hairline" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardLaborParticipation"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="@dimen/space_sm"
                app:cardCornerRadius="16dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/header_navy">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/space_lg" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LABOR PARTICIPATION" android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_secondary" android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.1" />
                    <TextView android:id="@+id/tvLaborValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="&#8212;"
                        android:textColor="@color/card_white" android:textSize="@dimen/text_display"
                        android:fontFamily="serif" android:textStyle="bold" android:layout_marginTop="@dimen/space_xs" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_xs">
                        <View android:id="@+id/viewLaborIndicatorDot" android:layout_width="8dp"
                            android:layout_height="8dp" android:layout_marginEnd="@dimen/space_sm" />
                        <TextView android:id="@+id/tvLaborStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="&#8212;"
                            android:textColor="@color/text_on_navy_muted" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="% of population" android:textColor="@color/slate_dim" android:textSize="@dimen/text_caption" android:layout_marginTop="@dimen/space_hairline" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl" app:cardCornerRadius="16dp"
            app:cardElevation="6dp" app:cardBackgroundColor="@color/header_navy">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingHorizontal="@dimen/space_xl" android:paddingTop="@dimen/space_lg">
                    <TextView android:id="@+id/tvChartTitle" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Unemployment Rate Trend"
                        android:textColor="@color/card_white" android:textSize="@dimen/text_body" android:fontFamily="serif" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:layout_marginTop="@dimen/space_sm" android:background="@color/accent_gold" />
                </LinearLayout>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/swappableChart"
                    android:layout_width="match_parent" android:layout_height="300dp" android:padding="@dimen/space_md" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
