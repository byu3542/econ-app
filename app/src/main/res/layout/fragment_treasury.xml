<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/space_lg">

            <!-- 10Y-2Y SPREAD CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpreadYoY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_sm"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10Y - 2Y"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_secondary"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvSpreadValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_display"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/space_xs"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/space_xs">

                        <View
                            android:id="@+id/viewSpreadIndicatorDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="@dimen/space_sm" />

                        <TextView
                            android:id="@+id/tvIndicatorText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOADING"
                            android:textColor="@color/text_muted"
                            android:textSize="@dimen/text_caption"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 10Y-3M SPREAD CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpread3M"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10Y - 3M"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_secondary"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvSpread3MValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_display"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/space_xs"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/space_xs">

                        <View
                            android:id="@+id/viewSpread3MIndicatorDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="@dimen/space_sm" />

                        <TextView
                            android:id="@+id/tvIndicator3MText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOADING"
                            android:textColor="@color/text_muted"
                            android:textSize="@dimen/text_caption"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- 10Y-2Y SPREAD TREND SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10Y-2Y Spread Trend"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/spreadChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:padding="@dimen/space_md"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 10Y-3M SPREAD TREND SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10Y-3M Spread Trend"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/spread3MChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:padding="@dimen/space_md"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TREASURY YIELD CURVE SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Yield Curve"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/yieldCurveChart"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:padding="@dimen/space_md"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 10-YEAR TREASURY YIELD TREND SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10-Year Trend"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_title"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/tenYearTrendChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:padding="@dimen/space_md"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
