<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- INFLATION BADGE ROW 1 — PCE | CPI-U side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false">

            <!-- PCE Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPceStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1C2236">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PCE INFLATION"
                        android:textColor="#C8A84B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvPceValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <View
                            android:id="@+id/viewPceDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tvPceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPcePercentile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#5A6A8A"
                        android:textSize="9sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CPI-U Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCpiYoY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1C2236">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPI-U YOY"
                        android:textColor="#C8A84B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvCpiYoYValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <View
                            android:id="@+id/viewCpiIndicatorDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tvCpiYoYStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCpiPercentile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#5A6A8A"
                        android:textSize="9sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- INFLATION BADGE ROW 2 — Real Wage Growth (full-width, odd badge) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWageYoY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1C2236">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REAL WAGE GROWTH"
                    android:textColor="#C8A84B"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvWageYoYValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u2014"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <View
                        android:id="@+id/viewWageIndicatorDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_neutral"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvWageYoYStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wages vs CPI spread"
                    android:textColor="#5A6A8A"
                    android:textSize="9sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════════════
             PCE vs CPI-U YEAR-OVER-YEAR CHART (with LimitLines)
             ═══════════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PCE vs CPI-U (Year-over-Year)"
                        android:textColor="#1C2236"
                        android:textSize="15sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <!-- Legend strip -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <View
                            android:layout_width="24dp"
                            android:layout_height="3dp"
                            android:background="#4285F4"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PCE"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:layout_marginEnd="12dp" />

                        <View
                            android:layout_width="24dp"
                            android:layout_height="3dp"
                            android:background="#fbbc04"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CPI-U"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:layout_marginEnd="12dp" />

                        <View
                            android:layout_width="24dp"
                            android:layout_height="1dp"
                            android:background="#4CAF50"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2% Target"
                            android:textColor="#888888"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/accent_gold" />
                </LinearLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartPceCpi"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="16dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════════════
             INFLATION vs WAGE GROWTH — INDEXED (Base = 100)
             ═══════════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inflation vs Wage Growth"
                        android:textColor="#1C2236"
                        android:textSize="15sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <!-- Legend strip -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <View
                            android:layout_width="24dp"
                            android:layout_height="3dp"
                            android:background="#fbbc04"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consumer Prices (CPI)"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:layout_marginEnd="12dp" />

                        <View
                            android:layout_width="24dp"
                            android:layout_height="3dp"
                            android:background="#9c27b0"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Average Wages"
                            android:textColor="#888888"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/accent_gold" />
                </LinearLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/comparisonChart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="16dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
