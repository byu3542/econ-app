<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- BADGE ROW 1: PCE | CPI-U -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_sm"
            android:baselineAligned="false">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPceStatus"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="@dimen/space_xs"
                app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/card_navy_badge">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/space_lg" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PCE INFLATION" android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption" android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvPceValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="&#8212;"
                        android:textColor="@color/card_white" android:textSize="@dimen/text_display" android:textStyle="bold" android:layout_marginTop="@dimen/space_xs" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_xs">
                        <View android:id="@+id/viewPceDot" android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@drawable/dot_neutral" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:id="@+id/tvPceStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="&#8212;"
                            android:textColor="@color/text_on_navy_muted" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvPcePercentile" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/slate_dim" android:textSize="@dimen/text_caption" android:layout_marginTop="@dimen/space_hairline" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardCpiYoY"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="@dimen/space_xs"
                app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/card_navy_badge">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/space_lg" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CPI-U YOY" android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption" android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvCpiYoYValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="&#8212;"
                        android:textColor="@color/card_white" android:textSize="@dimen/text_display" android:textStyle="bold" android:layout_marginTop="@dimen/space_xs" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_xs">
                        <View android:id="@+id/viewCpiIndicatorDot" android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@drawable/dot_neutral" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:id="@+id/tvCpiYoYStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="&#8212;"
                            android:textColor="@color/text_on_navy_muted" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvCpiPercentile" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/slate_dim" android:textSize="@dimen/text_caption" android:layout_marginTop="@dimen/space_hairline" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- BADGE ROW 2: Real Wage Growth (full width) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWageYoY"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_lg"
            app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/card_navy_badge">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="@dimen/space_lg" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="REAL WAGE GROWTH" android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_caption" android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.08" />
                <TextView android:id="@+id/tvWageYoYValue" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="&#8212;"
                    android:textColor="@color/card_white" android:textSize="@dimen/text_display" android:textStyle="bold" android:layout_marginTop="@dimen/space_xs" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_xs">
                    <View android:id="@+id/viewWageIndicatorDot" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/dot_neutral" android:layout_marginEnd="@dimen/space_xs" />
                    <TextView android:id="@+id/tvWageYoYStatus" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="&#8212;"
                        android:textColor="@color/text_on_navy_muted" android:textSize="@dimen/text_caption" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Wages vs CPI spread" android:textColor="@color/slate_dim" android:textSize="@dimen/text_caption" android:layout_marginTop="@dimen/space_hairline" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- PCE vs CPI-U CHART -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl" app:cardCornerRadius="16dp"
            app:cardElevation="6dp" app:cardBackgroundColor="@color/header_navy">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingHorizontal="@dimen/space_xl" android:paddingTop="@dimen/space_lg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PCE vs CPI-U (Year-over-Year)" android:textColor="@color/card_white"
                        android:textSize="@dimen/text_body" android:fontFamily="serif" android:textStyle="bold" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="@dimen/space_xs">
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="@color/google_blue"
                            android:layout_gravity="center_vertical" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="PCE" android:textColor="@color/slate_soft" android:textSize="@dimen/text_caption" android:layout_marginEnd="@dimen/space_md" />
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="@color/google_amber"
                            android:layout_gravity="center_vertical" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CPI-U" android:textColor="@color/slate_soft" android:textSize="@dimen/text_caption" android:layout_marginEnd="@dimen/space_md" />
                        <View android:layout_width="24dp" android:layout_height="1dp" android:background="@color/signal_good"
                            android:layout_gravity="center_vertical" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="2% Target" android:textColor="@color/slate_soft" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:layout_marginTop="@dimen/space_sm" android:background="@color/accent_gold" />
                </LinearLayout>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartPceCpi"
                    android:layout_width="match_parent" android:layout_height="300dp" android:padding="@dimen/space_md" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- INFLATION vs WAGE GROWTH CHART -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl" app:cardCornerRadius="16dp"
            app:cardElevation="6dp" app:cardBackgroundColor="@color/header_navy">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingHorizontal="@dimen/space_xl" android:paddingTop="@dimen/space_lg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Inflation vs Wage Growth" android:textColor="@color/card_white"
                        android:textSize="@dimen/text_body" android:fontFamily="serif" android:textStyle="bold" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="@dimen/space_xs">
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="@color/google_amber"
                            android:layout_gravity="center_vertical" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Consumer Prices (CPI)" android:textColor="@color/slate_soft" android:textSize="@dimen/text_caption" android:layout_marginEnd="@dimen/space_md" />
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="@color/accent_purple"
                            android:layout_gravity="center_vertical" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Average Wages" android:textColor="@color/slate_soft" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:layout_marginTop="@dimen/space_sm" android:background="@color/accent_gold" />
                </LinearLayout>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/comparisonChart"
                    android:layout_width="match_parent" android:layout_height="300dp" android:padding="@dimen/space_md" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
