<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_lg"
            android:baselineAligned="false">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardGdpStatus"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="@dimen/space_xs"
                app:cardCornerRadius="12dp" app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_navy_badge">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/space_lg" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="4Q ROLLING AVG" android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption" android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvGdpLatest" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="&#8212;"
                        android:textColor="@color/card_white" android:textSize="@dimen/text_display" android:textStyle="bold" android:layout_marginTop="@dimen/space_xs" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_xs">
                        <View android:id="@+id/viewGdpIndicatorDot" android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@drawable/dot_neutral" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:id="@+id/tvGdpStatusText" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="&#8212;"
                            android:textColor="@color/text_on_navy_muted" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvGdpDesc" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Annualized % change"
                        android:textColor="@color/slate_dim" android:textSize="@dimen/text_caption" android:layout_marginTop="@dimen/space_hairline" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardGdpLatestQuarter"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="@dimen/space_xs"
                app:cardCornerRadius="12dp" app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_navy_badge">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/space_lg" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LATEST QUARTER" android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption" android:textStyle="bold" android:textAllCaps="true" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvGdpLatestQuarterValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="&#8212;"
                        android:textColor="@color/card_white" android:textSize="@dimen/text_display" android:textStyle="bold" android:layout_marginTop="@dimen/space_xs" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_xs">
                        <View android:id="@+id/viewGdpLatestQuarterDot" android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@drawable/dot_neutral" android:layout_marginEnd="@dimen/space_xs" />
                        <TextView android:id="@+id/tvGdpLatestQuarterStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="&#8212;"
                            android:textColor="@color/text_on_navy_muted" android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvGdpLatestQuarterLabel" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/slate_dim" android:textSize="@dimen/text_caption" android:layout_marginTop="@dimen/space_hairline" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl" app:cardCornerRadius="16dp"
            app:cardElevation="6dp" app:cardBackgroundColor="@color/header_navy">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingHorizontal="@dimen/space_xl" android:paddingTop="@dimen/space_lg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GDP Growth (Quarterly)" android:textColor="@color/card_white"
                        android:textSize="@dimen/text_body" android:fontFamily="serif" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:layout_marginTop="@dimen/space_sm" android:background="@color/accent_gold" />
                </LinearLayout>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/gdpChart"
                    android:layout_width="match_parent" android:layout_height="300dp" android:padding="@dimen/space_md" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
