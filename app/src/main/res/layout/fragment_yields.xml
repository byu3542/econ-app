<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- TICKET-18: per-screen retry chip (hidden until this screen's fetch fails) -->
        <include layout="@layout/view_retry_chip" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl" app:cardCornerRadius="16dp"
            app:cardElevation="6dp" app:cardBackgroundColor="@color/header_navy">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingHorizontal="@dimen/space_xl" android:paddingTop="@dimen/space_lg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Current Yield Curve" android:textColor="@color/card_white"
                        android:textSize="@dimen/text_body" android:fontFamily="serif" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:layout_marginTop="@dimen/space_sm" android:background="@color/accent_gold" />
                </LinearLayout>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/yieldCurveChart"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Treasury yield curve chart"
                    android:layout_width="match_parent" android:layout_height="300dp" android:padding="@dimen/space_md" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl" app:cardCornerRadius="16dp"
            app:cardElevation="6dp" app:cardBackgroundColor="@color/surface_card">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@color/header_navy" android:paddingHorizontal="@dimen/space_xl" android:paddingVertical="@dimen/space_lg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Treasury Yields" android:textColor="@color/card_white"
                        android:textSize="@dimen/text_headline" android:fontFamily="serif" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                        android:background="@drawable/badge_gold_filled" android:paddingHorizontal="@dimen/space_md"
                        android:paddingVertical="@dimen/space_xs" android:text="LIVE" android:textColor="@color/header_navy"
                        android:textSize="@dimen/text_caption" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:layout_alignParentBottom="true" android:background="@color/accent_gold" />
                </RelativeLayout>
                <include layout="@layout/row_section_alt" android:id="@+id/row1M" />
                <include layout="@layout/row_section" android:id="@+id/row3M" />
                <include layout="@layout/row_section_alt" android:id="@+id/row2Y" />
                <include layout="@layout/row_section" android:id="@+id/row10Y" />
                <include layout="@layout/row_section_alt" android:id="@+id/row30Y" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
