<?xml version="1.0" encoding="utf-8"?>
<!-- Dark navy badge card — matches Housing tab badge style.
     Used by Overview screen for the 2x2 KPI indicator grid. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1C2236">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:gravity="center">

        <!-- Label: indicator name (gold, all-caps) -->
        <TextView
            android:id="@+id/tvMetricLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="METRIC"
            android:textColor="#C8A84B"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08" />

        <!-- Value: the percentage / number -->
        <TextView
            android:id="@+id/tvMetricValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\u2014"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <!-- Status row: colored dot + status word -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <View
                android:id="@+id/viewTierDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_neutral"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvTierStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u2014"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Sub-label: date -->
        <TextView
            android:id="@+id/tvMetricDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#5A6A8A"
            android:textSize="9sp"
            android:layout_marginTop="2dp" />

        <!-- Sub-label: historical percentile (when available) -->
        <TextView
            android:id="@+id/tvPercentile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#5A6A8A"
            android:textSize="9sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
