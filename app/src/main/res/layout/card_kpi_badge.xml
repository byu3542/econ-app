<?xml version="1.0" encoding="utf-8"?>
<!-- Dark navy badge card — matches Housing tab badge style.
     Used by Overview screen for the KPI indicator grid.
     Tappable (ripple foreground); shows value + delta chip + sparkline. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_navy_badge">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:gravity="center">

        <!-- Label: indicator name (gold, all-caps) -->
        <TextView
            android:id="@+id/tvMetricLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="METRIC"
            android:textColor="@color/accent_gold"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08" />

        <!-- Value + delta vs. previous release -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvMetricValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMetricDelta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Sparkline: recent trend from local history -->
        <com.economic.dashboard.ui.views.SparklineView
            android:id="@+id/sparkline"
            android:layout_width="90dp"
            android:layout_height="20dp"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:importantForAccessibility="no" />

        <!-- Status row: colored dot + status word -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <View
                android:id="@+id/viewTierDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_neutral"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvTierStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_slate"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Sub-label: date -->
        <TextView
            android:id="@+id/tvMetricDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_slate"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />

        <!-- Sub-label: historical percentile (when available) -->
        <TextView
            android:id="@+id/tvPercentile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_slate"
            android:textSize="10sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
