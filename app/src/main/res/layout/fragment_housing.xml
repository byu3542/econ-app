<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══════════════════════════════════════════════════════════════════
             HOUSING METRIC BADGES — Housing Starts & Existing Home Sales
             ═══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:baselineAligned="false">

            <!-- HOUSING STARTS Badge -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOUSING STARTS"
                        android:textColor="@color/accent_gold"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvStartsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <View
                            android:id="@+id/viewStartsDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tvStartsStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_muted"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- HOME SALES Badge -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOME SALES"
                        android:textColor="@color/accent_gold"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvSalesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <View
                            android:id="@+id/viewSalesDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tvSalesStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_muted"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════════
             MBS BADGE ROW — Tappable badges for 30-Yr Rate, Bank MBS, Fed MBS
             ═══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:baselineAligned="false">

            <!-- 30-YR RATE Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/badgeMortgage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30-YR RATE"
                        android:textColor="@color/accent_gold"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvBadgeMortgageValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <View
                            android:id="@+id/viewBadgeMortgageDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tvBadgeMortgageStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_muted"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BANK MBS Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/badgeBankMbs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BANK MBS"
                        android:textColor="@color/accent_gold"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvBadgeBankMbsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <View
                            android:id="@+id/viewBadgeBankMbsDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tvBadgeBankMbsStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_muted"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- FED MBS Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/badgeFedMbs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FED MBS"
                        android:textColor="@color/accent_gold"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvBadgeFedMbsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <View
                            android:id="@+id/viewBadgeFedMbsDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:id="@+id/tvBadgeFedMbsStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_muted"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════════
             SWAPPABLE CHART — Changes based on selected badge
             ═══════════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#1C2236">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1C2236"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:id="@+id/tvSwappableTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30-Year Mortgage Rate (%)"
                        android:textColor="#E8F0FF"
                        android:textSize="14sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartSwappable"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:padding="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════════════
             MBS & MORTGAGE RATES CHART
             ═══════════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#1C2236">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1C2236"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MBS &amp; Mortgage Rates"
                        android:textColor="#E8F0FF"
                        android:textSize="15sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartMbsMortgage"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:padding="16dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
