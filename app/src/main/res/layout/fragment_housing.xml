<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- TICKET-18: per-screen retry chip (hidden until this screen's fetch fails) -->
        <include layout="@layout/view_retry_chip" />

        <!-- ═══════════════════════════════════════════════════════════════════
             HOUSING METRIC BADGES — Housing Starts & Existing Home Sales
             ═══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_lg"
            android:baselineAligned="false">

            <!-- HOUSING STARTS Badge -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_sm"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOUSING STARTS"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvStartsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/space_hairline" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/space_hairline">

                        <View
                            android:id="@+id/viewStartsDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="@dimen/space_xs" />

                        <TextView
                            android:id="@+id/tvStartsStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_on_navy_muted"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- HOME SALES Badge -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOME SALES"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvSalesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/space_hairline" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/space_hairline">

                        <View
                            android:id="@+id/viewSalesDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="@dimen/space_xs" />

                        <TextView
                            android:id="@+id/tvSalesStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_on_navy_muted"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════════
             RATES BADGE ROW — Tappable badges for 30-Yr Rate, 10Y Treasury, Spread
             ═══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_lg"
            android:baselineAligned="false">

            <!-- 30-YR RATE Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/badgeMortgage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_sm"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30-YR RATE"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- TICKET-21: screen hero \u2014 largest type -->
                    <TextView
                        android:id="@+id/tvBadgeMortgageValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_headline"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/space_hairline" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/space_hairline">

                        <View
                            android:id="@+id/viewBadgeMortgageDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="@dimen/space_xs" />

                        <TextView
                            android:id="@+id/tvBadgeMortgageStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_on_navy_muted"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 10Y T-RATE Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/badge10Y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="@dimen/space_xs"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10Y T-RATE"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- TICKET-21: demoted sibling \u2014 muted -->
                    <TextView
                        android:id="@+id/tvBadge10YValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/text_on_navy_muted"
                        android:textSize="@dimen/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/space_hairline" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/space_hairline">

                        <View
                            android:id="@+id/viewBadge10YDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="@dimen/space_xs" />

                        <TextView
                            android:id="@+id/tvBadge10YStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_on_navy_muted"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SPREAD Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/badgeSpread"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/header_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPREAD"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- TICKET-21: demoted sibling \u2014 muted -->
                    <TextView
                        android:id="@+id/tvBadgeSpreadValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2014"
                        android:textColor="@color/text_on_navy_muted"
                        android:textSize="@dimen/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/space_hairline" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/space_hairline">

                        <View
                            android:id="@+id/viewBadgeSpreadDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/dot_neutral"
                            android:layout_marginEnd="@dimen/space_xs" />

                        <TextView
                            android:id="@+id/tvBadgeSpreadStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2014"
                            android:textColor="@color/text_on_navy_muted"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════════
             SWAPPABLE CHART — Changes based on selected badge
             ═══════════════════════════════════════════════════════════════════ -->
        <!-- TICKET-11: inline range switcher (drives both Housing charts) -->
        <include layout="@layout/view_timeframe_selector" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_navy_badge">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/card_navy_badge"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:id="@+id/tvSwappableTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30-Year Mortgage Rate (%)"
                        android:textColor="@color/info_blue_tint"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartSwappable"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Housing market trend chart"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:padding="@dimen/space_md" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════════════
             MBS & MORTGAGE RATES CHART
             ═══════════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_navy_badge">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/card_navy_badge"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MBS &amp; Mortgage Rates"
                        android:textColor="@color/info_blue_tint"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartMbsMortgage"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Mortgage rate and MBS spread chart"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:padding="@dimen/space_lg" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
