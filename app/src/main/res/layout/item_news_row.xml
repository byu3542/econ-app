<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="3dp"
    app:cardBackgroundColor="@color/surface_card"
    app:cardElevation="1dp"
    app:cardCornerRadius="10dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Impact bar on left edge (description set in adapter for TalkBack) -->
        <View
            android:id="@+id/view_impact_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="10dp" />

        <!-- Content column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Source + time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_row_source"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:textColor="@color/accent_gold" />

                <TextView
                    android:id="@+id/tv_row_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted" />

            </LinearLayout>

            <!-- Headline -->
            <TextView
                android:id="@+id/tv_row_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:textColor="@color/text_navy"
                android:lineHeight="18sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Tag chip -->
            <TextView
                android:id="@+id/tv_row_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

        </LinearLayout>

        <!-- Optional thumbnail (only when the feed provides one) -->
        <ImageView
            android:id="@+id/iv_row_thumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:layout_gravity="center_vertical"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:importantForAccessibility="no" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
