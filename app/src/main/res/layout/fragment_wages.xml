<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- TICKET-18: per-screen retry chip (hidden until this screen's fetch fails) -->
        <include layout="@layout/view_retry_chip" />

        <!-- REAL WAGE GROWTH CARD (GDP Style) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWageYoY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/header_navy">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_2xl"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvWageYoYLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real Wage Growth v. Inflation (YOY %)"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textAlignment="center"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvWageYoYValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/card_white"
                    android:textSize="@dimen/text_display_xl"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/space_sm"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/space_xs">

                    <View
                        android:id="@+id/viewWageIndicatorDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_neutral"
                        android:layout_marginEnd="@dimen/space_sm" />

                    <TextView
                        android:id="@+id/tvWageYoYStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comparing Wages vs Inflation"
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_secondary"
                        android:textAlignment="center"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWageYoYDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Annualized % difference"
                    android:textColor="@color/text_muted"
                    android:textSize="@dimen/text_caption"
                    android:layout_marginTop="@dimen/space_hairline"
                    android:visibility="gone"
                    android:textAlignment="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TICKET-20: inline range switcher — drives both Wages charts -->
        <include layout="@layout/view_timeframe_selector" />

        <!-- AVERAGE HOURLY EARNINGS SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Average Hourly Earnings"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_headline"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/hourlyWageChart"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Average hourly earnings trend chart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="@dimen/space_lg"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- INFLATION VS WAGE GROWTH SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inflation vs Wage Growth"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_headline"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/comparisonChart"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Wages versus inflation comparison chart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="@dimen/space_lg"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
