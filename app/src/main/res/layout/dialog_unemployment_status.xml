<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/header_navy"
    android:padding="@dimen/space_2xl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="UNEMPLOYMENT BENCHMARKS"
        android:textColor="@color/accent_gold"
        android:textSize="@dimen/text_secondary"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="@dimen/space_xl"
        android:gravity="center" />

    <!-- Benchmark Table Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/navy_surface_deep"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <!-- Healthy Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_good"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEALTHY"
                        android:textColor="@color/signal_good_soft"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.5-4.5% rate AND rising &lt; 0.3% from low"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Watch Closely Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_watch"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WATCH CLOSELY"
                        android:textColor="@color/signal_watch_soft"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.5-4.5% rate AND rising 0.3-0.5% from low"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Elevated Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_elevated"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ELEVATED"
                        android:textColor="@color/signal_elevated_soft"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level above 5.5% regardless of trend"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Sahm Rule Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_alert"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECESSION SIGNAL"
                        android:textColor="@color/signal_alert_soft"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rising 0.5%+ from 12-mo low (Sahm Rule)"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Territory Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_alert_deep"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECESSION TERRITORY"
                        android:textColor="@color/signal_alert_soft"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level above 7.0% regardless of trend"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISMISS"
        android:textColor="@color/accent_gold"
        android:textSize="@dimen/text_secondary"
        android:textStyle="bold"
        android:padding="@dimen/space_lg"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/space_sm" />

</LinearLayout>
