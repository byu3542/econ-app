<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/header_navy"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="UNEMPLOYMENT BENCHMARKS"
        android:textColor="@color/accent_gold"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <!-- Benchmark Table Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#1F2633"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Healthy Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEALTHY"
                        android:textColor="#A5D6A7"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.5-4.5% rate AND rising &lt; 0.3% from low"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Watch Closely Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#FFEB3B"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WATCH CLOSELY"
                        android:textColor="#FFF59D"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.5-4.5% rate AND rising 0.3-0.5% from low"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Elevated Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#FF9800"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ELEVATED"
                        android:textColor="#FFCC80"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level above 5.5% regardless of trend"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Sahm Rule Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#F44336"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECESSION SIGNAL"
                        android:textColor="#EF9A9A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rising 0.5%+ from 12-mo low (Sahm Rule)"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Territory Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#B71C1C"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECESSION TERRITORY"
                        android:textColor="#EF9A9A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level above 7.0% regardless of trend"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISMISS"
        android:textColor="@color/accent_gold"
        android:textSize="12sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:layout_gravity="end"
        android:layout_marginTop="8dp" />

</LinearLayout>
