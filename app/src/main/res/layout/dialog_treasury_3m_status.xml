<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/header_navy"
    android:padding="@dimen/space_2xl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="10Y - 3M SPREAD BENCHMARKS"
        android:textColor="@color/accent_gold"
        android:textSize="@dimen/text_secondary"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="@dimen/space_xl"
        android:gravity="center" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/navy_surface_deep"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <!-- Steep Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/accent_purple"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEEP — POTENTIAL OVERHEATING"
                        android:textColor="@color/accent_purple_soft"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+3.50% or more"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Strong Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/info_blue"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STRONG"
                        android:textColor="@color/info_blue_soft"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+2.00% to +3.50%"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Healthy Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_good"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEALTHY"
                        android:textColor="@color/signal_good_tint"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1.00% to +2.00%"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Recovering Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_watch"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECOVERING — STILL IN DANGER WINDOW"
                        android:textColor="@color/signal_watch_tint"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% to +1.00%"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Flattening Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_watch"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FLATTENING — WATCH CLOSELY"
                        android:textColor="@color/signal_watch_tint"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-0.50% to 0%"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Inverted Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_elevated"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INVERTED — ELEVATED RECESSION RISK"
                        android:textColor="@color/signal_elevated_tint"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-1.50% to -0.50%"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/navy_divider" />

            <!-- Deep Inversion Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/space_md">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="@color/signal_alert"
                    android:layout_marginEnd="@dimen/space_lg" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEEP INVERSION — STRONG RECESSION SIGNAL"
                        android:textColor="@color/signal_alert_tint"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Below -1.50%"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISMISS"
        android:textColor="@color/accent_gold"
        android:textSize="@dimen/text_secondary"
        android:textStyle="bold"
        android:padding="@dimen/space_lg"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/space_sm" />

</LinearLayout>
