<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_md"
    android:layout_marginTop="@dimen/space_sm"
    android:layout_marginBottom="@dimen/space_sm"
    app:cardElevation="3dp"
    app:cardCornerRadius="12dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gold accent bar at top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/accent_gold" />

        <!-- Source row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingBottom="@dimen/space_xs">

            <TextView
                android:id="@+id/tv_hero_source"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textColor="@color/accent_gold" />

            <TextView
                android:id="@+id/tv_hero_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_muted" />

        </LinearLayout>

        <!-- Headline -->
        <TextView
            android:id="@+id/tv_hero_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_sm"
            android:textSize="@dimen/text_body"
            android:fontFamily="serif"
            android:textColor="@color/text_navy"
            android:lineHeight="22sp"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- Summary -->
        <TextView
            android:id="@+id/tv_hero_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_xs"
            android:layout_marginBottom="@dimen/space_lg"
            android:textSize="@dimen/text_secondary"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
