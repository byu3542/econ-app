<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/header_navy"
    android:padding="@dimen/space_2xl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FED FUNDS RATE HISTORY"
        android:textColor="@color/accent_gold"
        android:textSize="@dimen/text_secondary"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="@dimen/space_xl"
        android:gravity="center" />

    <!-- Table Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_md"
        android:paddingBottom="@dimen/space_sm">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DATE"
            android:textColor="@color/text_on_navy_muted"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RATE"
            android:textColor="@color/text_on_navy_muted"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold"
            android:gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CHANGE"
            android:textColor="@color/text_on_navy_muted"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="400dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/navy_surface_deep"
        app:cardElevation="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFedFundsHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/space_xs"
            android:clipToPadding="false" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISMISS"
        android:textColor="@color/accent_gold"
        android:textSize="@dimen/text_secondary"
        android:textStyle="bold"
        android:padding="@dimen/space_lg"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/space_sm" />

</LinearLayout>
