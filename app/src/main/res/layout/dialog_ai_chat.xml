<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom-sheet layout for the AI Economic Analyst panel.
  Height is set programmatically to ~62% of screen in MainActivity.
  Uses a vertical LinearLayout so the RecyclerView can flex with weight=1.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_warm_off_white">

    <!-- Header area with Navy background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/header_navy">

        <!-- Drag handle -->
        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"
            android:background="#26000000"
            android:importantForAccessibility="no" />

        <!-- Header row -->
        <RelativeLayout
            android:id="@+id/rlHeader"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_ai_agent"
                    android:layout_marginEnd="8dp"
                    app:tint="@color/accent_gold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI ECONOMIC ANALYST"
                    android:textColor="@color/accent_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                app:tint="@color/card_white" />

        </RelativeLayout>

    </LinearLayout>

    <!-- Header divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/accent_gold" />

    <!-- Quick-ask chip row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ASK ABOUT"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipRecentNews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent News"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipRecentUpdates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Economic Updates"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipYieldCurve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yield curve health"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipRecession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recession risk?"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipWages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Real wage trend"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Chat messages — flex-fills remaining space -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"
        android:clipChildren="false" />

    <!-- Input area -->
    <LinearLayout
        android:id="@+id/llInputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_capsule"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Ask about the economy..."
                android:background="@null"
                android:textColor="@color/text_navy"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:inputType="textCapSentences" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_send_filled"
                android:background="@drawable/bg_send_button_circle"
                app:tint="@color/accent_gold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Disclaimer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Responses use live Treasury · BEA · BLS data"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingBottom="16dp" />

</LinearLayout>
