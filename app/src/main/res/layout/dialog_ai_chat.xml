<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <!-- Header with Close Button -->
    <RelativeLayout
        android:id="@+id/rlHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="AI ECONOMIC ANALYST"
            android:textColor="@color/accent_gold"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.2" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="@color/text_secondary" />

    </RelativeLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/rlHeader"
        android:background="@color/divider_sand" />

    <!-- Top Label -->
    <TextView
        android:id="@+id/tvAskAboutLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerDivider"
        android:text="ASK ABOUT"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp" />

    <!-- Chips Horizontal Scroll -->
    <HorizontalScrollView
        android:id="@+id/svChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvAskAboutLabel"
        android:scrollbars="none"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipYieldCurve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yield curve health"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipRecession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recession risk?"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipWages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Real wage trend"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/svChips"
        android:layout_above="@id/llInputArea"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Input Area Footer -->
    <LinearLayout
        android:id="@+id/llInputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/tvDisclaimer"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_capsule"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Ask about the economy..."
                android:background="@null"
                android:textColor="@color/text_navy"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:inputType="textCapSentences" />

            <ImageButton
                android:id="@+id/btnOptions"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_unfold_more"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_send_filled"
                android:background="@drawable/bg_send_button_circle"
                app:tint="@color/accent_gold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Disclaimer Text -->
    <TextView
        android:id="@+id/tvDisclaimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="Responses use live Treasury · BEA · BLS data"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingBottom="16dp" />

</RelativeLayout>
