<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom-sheet layout for the AI Economic Analyst panel.
  Height is set programmatically in AiAnalystBottomSheet (full screen,
  keyboard-aware). Vertical LinearLayout so the chat area can flex.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_warm_off_white">

    <!-- Header area with Navy background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/header_navy">

        <!-- Drag handle -->
        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_md"
            android:layout_marginBottom="@dimen/space_xs"
            android:background="@color/handle_on_surface"
            android:importantForAccessibility="no" />

        <!-- Header row -->
        <RelativeLayout
            android:id="@+id/rlHeader"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="@dimen/space_lg">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btnClearChat"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_ai_agent"
                    android:layout_marginEnd="@dimen/space_sm"
                    app:tint="@color/accent_gold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI ANALYST"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:letterSpacing="0.2" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnClearChat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_toStartOf="@+id/btnClose"
                android:layout_marginEnd="@dimen/space_sm"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_clear_chat"
                android:contentDescription="Clear conversation"
                android:alpha="0.7"
                app:tint="@color/card_white" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="Close"
                app:tint="@color/card_white" />

        </RelativeLayout>

    </LinearLayout>

    <!-- Header divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/accent_gold" />

    <!-- Quick-ask chip row -->
    <TextView
        android:id="@+id/tvAskAbout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ASK ABOUT"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_caption"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginStart="@dimen/space_lg" />

    <HorizontalScrollView
        android:id="@+id/hsvChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_sm"
        android:clipToPadding="false"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipRecentNews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent News"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="@dimen/space_sm"
                android:textSize="@dimen/text_secondary"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="@dimen/space_sm"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipRecentUpdates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Economic Updates"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="@dimen/space_sm"
                android:textSize="@dimen/text_secondary"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="@dimen/space_sm"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipYieldCurve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yield curve health"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="@dimen/space_sm"
                android:textSize="@dimen/text_secondary"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="@dimen/space_sm"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipRecession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recession risk?"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="@dimen/space_sm"
                android:textSize="@dimen/text_secondary"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="@dimen/space_sm"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipWages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Real wage trend"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="@dimen/space_sm"
                android:textSize="@dimen/text_secondary"
                android:textColor="@color/text_secondary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Chat messages + scroll-to-bottom pill -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/space_lg"
            android:clipToPadding="false"
            android:clipChildren="false" />

        <!-- Empty state: shown until the first message is sent -->
        <LinearLayout
            android:id="@+id/llEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="40dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_ai_agent"
                app:tint="@color/accent_gold"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="Your AI Economic Analyst"
                android:textColor="@color/text_navy"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="Ask anything about the economy — answers use the live dashboard data and 24 months of history."
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_secondary"
                android:gravity="center"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/pillNewReply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/space_md"
            android:text="↓ New reply"
            android:textSize="@dimen/text_secondary"
            android:textColor="@color/accent_gold"
            android:background="@drawable/bg_pill_navy"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_sm"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Input area -->

    <!-- Pending image preview (vision analysis) -->
    <LinearLayout
        android:id="@+id/llImagePreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_sm"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivImagePreview"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:contentDescription="Attached image preview" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_md"
            android:text="Image attached — will be analyzed with your next message"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_caption" />

        <ImageButton
            android:id="@+id/btnRemoveImage"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_muted"
            android:contentDescription="Remove attached image" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llInputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/space_lg"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_capsule"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_sm">

            <ImageButton
                android:id="@+id/btnAttach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_attach_image"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_muted"
                android:contentDescription="Attach an image for analysis" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingVertical="@dimen/space_md"
                android:hint="Ask about the economy..."
                android:background="@null"
                android:textColor="@color/text_navy"
                android:textColorHint="@color/text_muted"
                android:textSize="@dimen/text_body"
                android:inputType="textCapSentences"
                android:imeOptions="actionSend"
                android:maxLines="4" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_send_filled"
                android:background="@drawable/bg_send_button_circle"
                app:tint="@color/accent_gold"
                android:contentDescription="Send message"
                android:enabled="false"
                android:alpha="0.4"
                android:layout_marginStart="@dimen/space_sm" />

        </LinearLayout>

    </LinearLayout>

    <!-- Disclaimer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Responses use live Treasury · BEA · BLS data"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_caption"
        android:gravity="center"
        android:paddingBottom="@dimen/space_lg" />

</LinearLayout>
