<?xml version="1.0" encoding="utf-8"?>
<!--
  Markets fragment — Level 2 navigation.
  A cream-dark TabLayout sits at the top; the ViewPager2 fills the rest.
  Hosts: YieldsFragment | SpreadsFragment
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_warm_off_white">

    <!-- Secondary tab row: cream-dark bg, gold 2dp indicator -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/marketsTabLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        style="@style/EconomyTabLayout"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorHeight="2dp"
        app:tabPaddingStart="0dp"
        app:tabPaddingEnd="0dp"
        android:elevation="0dp" />

    <!-- Bottom border under tab row -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#14000000" />

    <!-- Child fragment content -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/marketsViewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
