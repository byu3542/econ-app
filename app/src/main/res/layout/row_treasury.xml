<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="4dp">

    <TextView android:id="@+id/tvMaturity"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="—"
        android:textSize="14sp" android:textColor="@color/textPrimary"/>

    <!-- Daily change in basis points vs. previous observation -->
    <TextView android:id="@+id/tvChange"
        android:layout_width="64dp" android:layout_height="wrap_content"
        android:gravity="end" android:text=""
        android:textSize="11sp" android:textStyle="bold"
        android:fontFeatureSettings="tnum"/>

    <TextView android:id="@+id/tvYield"
        android:layout_width="80dp" android:layout_height="wrap_content"
        android:gravity="end" android:text="—"
        android:textSize="14sp" android:textColor="@color/textPrimary"
        android:textStyle="bold" android:fontFeatureSettings="tnum"/>

    <TextView android:id="@+id/tvDate"
        android:layout_width="90dp" android:layout_height="wrap_content"
        android:gravity="end" android:text="—"
        android:textSize="11sp" android:textColor="@color/textSecondary"
        android:fontFeatureSettings="tnum"/>
</LinearLayout>
