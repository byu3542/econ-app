<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="10dp">

    <TextView android:id="@+id/tvMaturity"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="—"
        android:textSize="14sp" android:textColor="@color/textPrimary"/>
    <TextView android:id="@+id/tvYield"
        android:layout_width="80dp" android:layout_height="wrap_content"
        android:gravity="center" android:text="—"
        android:textSize="14sp" android:textColor="@color/textPrimary" android:textStyle="bold"/>
    <TextView android:id="@+id/tvDate"
        android:layout_width="100dp" android:layout_height="wrap_content"
        android:gravity="end" android:text="—"
        android:textSize="11sp" android:textColor="@color/textSecondary"/>
</LinearLayout>
