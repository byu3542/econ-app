<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- YoY INFLATION CARD (GDP Style) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCpiYoY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/header_navy">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCpiYoYLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inflation (YoY % Change)"
                    android:textColor="@color/accent_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvCpiYoYValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/card_white"
                    android:textSize="48sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <View
                        android:id="@+id/viewCpiIndicatorDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_neutral"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvCpiYoYStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading reading..."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCpiYoYDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Annualized % change"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CPI-U SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consumer Price Index (CPI-U)"
                        android:textColor="@color/card_white"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/cpiUChart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="16dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CPI-W SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPI-W All Items"
                        android:textColor="@color/card_white"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/cpiWChart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="16dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
