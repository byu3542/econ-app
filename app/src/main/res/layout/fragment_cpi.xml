<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- TICKET-18: per-screen retry chip (hidden until this screen's fetch fails) -->
        <include layout="@layout/view_retry_chip" />

        <!-- YoY INFLATION CARD (GDP Style) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCpiYoY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/header_navy">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_2xl"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCpiYoYLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inflation (YoY % Change)"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvCpiYoYValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/card_white"
                    android:textSize="@dimen/text_display_xl"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/space_sm"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/space_xs">

                    <View
                        android:id="@+id/viewCpiIndicatorDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_neutral"
                        android:layout_marginEnd="@dimen/space_sm" />

                    <TextView
                        android:id="@+id/tvCpiYoYStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading reading..."
                        android:textColor="@color/text_muted"
                        android:textSize="@dimen/text_secondary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCpiYoYDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Annualized % change"
                    android:textColor="@color/text_muted"
                    android:textSize="@dimen/text_caption"
                    android:layout_marginTop="@dimen/space_hairline"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TICKET-20: inline range switcher — drives both CPI charts -->
        <include layout="@layout/view_timeframe_selector" />

        <!-- CPI-U SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consumer Price Index (CPI-U)"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_headline"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/cpiUChart"
                    android:importantForAccessibility="yes"
                    android:contentDescription="CPI-U inflation trend chart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="@dimen/space_lg"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CPI-W SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2xl"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/header_navy"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPI-W All Items"
                        android:textColor="@color/card_white"
                        android:textSize="@dimen/text_headline"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/accent_gold" />
                </RelativeLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/cpiWChart"
                    android:importantForAccessibility="yes"
                    android:contentDescription="CPI-W inflation trend chart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:padding="@dimen/space_lg"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
