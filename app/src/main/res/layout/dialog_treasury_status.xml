<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/header_navy"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="10Y-2Y SPREAD BENCHMARKS"
        android:textColor="@color/accent_gold"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#1F2633"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Very Healthy Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VERY HEALTHY"
                        android:textColor="#A5D6A7"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1.50% or more (+150 bps)"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Healthy Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEALTHY"
                        android:textColor="#A5D6A7"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0.50% to +1.50% (+50 to +150 bps)"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Caution Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#FFEB3B"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CAUTION"
                        android:textColor="#FFF59D"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% to +0.50% (0 to +50 bps)"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Warning Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#FF9800"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WARNING"
                        android:textColor="#FFCC80"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-0.50% to 0% (-1 to 0 bps)"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A3342" />

            <!-- Danger Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_neutral"
                    android:backgroundTint="#F44336"
                    android:layout_marginEnd="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DANGER"
                        android:textColor="#EF9A9A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Below -0.50% (-50 bps or worse)"
                        android:textColor="@color/card_white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISMISS"
        android:textColor="@color/accent_gold"
        android:textSize="12sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:layout_gravity="end"
        android:layout_marginTop="8dp" />

</LinearLayout>
