<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardFedFundsHero"
    style="@style/FedFundsHeroCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_lg"
    android:backgroundTint="@null"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gold accent bar at top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/accent_gold" />

        <!-- Card content -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/space_xl"
            android:paddingVertical="@dimen/space_xl">

            <!-- Left: label · rate · history hint -->
            <LinearLayout
                android:id="@+id/llHeroLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FED FUNDS RATE"
                    android:textColor="@color/text_on_navy_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvFedFundsHeroValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_display_lg"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvFedFundsHeroLastUpdated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_on_navy_muted"
                    android:textSize="@dimen/text_caption"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="View history →"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/gold_muted"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <!-- Right: change chip · cycle note · FOMC date (all data-driven) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/change_fed_funds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/accent_gold"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_fed_change_chip"
                    android:paddingStart="@dimen/space_sm"
                    android:paddingEnd="@dimen/space_sm"
                    android:paddingTop="@dimen/space_xs"
                    android:paddingBottom="@dimen/space_xs"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvFedFundsHeroCycle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_on_navy_secondary"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvFedFundsHeroDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_hairline"
                    android:textColor="@color/text_on_navy_muted"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
