<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardFedFundsHero"
    style="@style/FedFundsHeroCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:backgroundTint="@null"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gold accent bar at top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/accent_gold" />

        <!-- Card content -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp">

            <!-- Left: label · rate · last-updated date -->
            <LinearLayout
                android:id="@+id/llHeroLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FED FUNDS RATE"
                    android:textColor="#80FFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvFedFundsHeroValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent_gold"
                    android:textSize="32sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvFedFundsHeroLastUpdated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#59FFFFFF"
                    android:textSize="9sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Right: change chip · cut-cycle note · FOMC date · history hint -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/change_fed_funds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="#c9a84c"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_fed_change_chip"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cut cycle ongoing"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="serif"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/tvFedFundsHeroDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Next FOMC: May"
                    android:textColor="#59FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="View history →"
                    android:textSize="7sp"
                    android:textColor="#44C9A84C"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
