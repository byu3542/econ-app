<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom navigation menu — 4 destinations + a disabled center placeholder.
  The center slot is empty; a circular ShapeableImageView (fabAiAnalyst)
  in activity_main.xml floats over it and opens the AI Analyst sheet.

  itemIconTint in activity_main.xml handles colour:
    active   → #c9a84c (gold)
    inactive → rgba(255,255,255,0.35)
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:id="@+id/nav_overview"
        android:icon="@drawable/ic_overview_selector"
        android:title="Overview" />

    <item
        android:id="@+id/nav_markets"
        android:icon="@drawable/ic_markets_selector"
        android:title="Markets" />

    <item
        android:id="@+id/nav_ai_placeholder"
        android:icon="@drawable/ic_blank"
        android:title=""
        android:enabled="false" />

    <item
        android:id="@+id/nav_economy"
        android:icon="@drawable/ic_economy_selector"
        android:title="Economy" />

    <item
        android:id="@+id/navigation_news"
        android:icon="@drawable/ic_news"
        android:title="News" />

</menu>
